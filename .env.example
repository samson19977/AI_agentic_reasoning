# Multi-Agent Research Assistant — Environment Variables
# Copy this file to .env and fill in your API keys.

# ── LLM Provider ────────────────────────────────────────────────────────────
# "groq" | "huggingface" | "auto" (tries Groq first, falls back to HF)
LLM_PROVIDER=auto

# ── Groq (fast inference) ───────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── HuggingFace Inference API (open-source models) ──────────────────────────
HF_TOKEN=hf_your-token-here
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct

# API / CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Auth ─────────────────────────────────────────────────────────────────────
# Static API key required on all /api/research/* endpoints via X-API-Key header.
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to allow unauthenticated access (local dev only).
API_KEY=your-strong-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (relative to api/ directory). Created automatically.
DB_PATH=data/jobs.db

# WhatsApp (optional)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# WHATSAPP_VERIFY_TOKEN=
# WEBHOOK_SECRET=


TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here



